# Telegram Credentials
# Get these from https://my.telegram.org (API ID/Hash) and @BotFather (Token)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram User ID (to restrict access)
# Get from @username_to_id_bot
TELEGRAM_AUTH_USER_ID=123456789

# Directory Configuration
# These are paths INSIDE the container.
# They should match the subfolders of the single volume mapped in docker-compose.yml
# Check inside the bot with `/checkconfig` command to see the expected paths.
# Example: If mapped volume is /mnt/media:/media, and the subfolders are /mnt/media/Movies, /mnt/media/Shows, and /mnt/media/Downloads, then:
MOVIES_DIR=/media/Movies
SHOWS_DIR=/media/Shows
WATCH_DIR=/media/Downloads

# Format for mnamer. You can see all available formats here: https://github.com/jkwill87/mnamer/wiki/Formatting
# Default works the best for Jellyfin for [movies](https://jellyfin.org/docs/general/server/media/movies/) and [shows](https://jellyfin.org/docs/general/server/media/shows/).
# With default configuration a movie will be renamed to "/media/Movies/Back to the Future (1985) [tmdbid-105]/Back to the Future (1985).mkv"
MOVIE_FORMAT="{name} ({year}){extension}"
MOVIE_DIRECTORY="{name} ({year}) [tmdbid-{id_tmdb}]" # Combined with MOVIES_DIR
# With default configuration a TV episode will be renamed to "/media/Shows/Breaking Bad [tvdbid-1396]/Season 01/Breaking Bad S01E01.mkv"
EPISODES_FORMAT="{series} S{season:02}E{episode:02}{extension}"
EPISODE_DIRECTORY="{series} [tvdbid-{id_tvdb}]/Season {season:02}" # Combined with SHOWS_DIR

# Language for mnamer (en, es, etc.)
LANGUAGE=en

# Docker User/Group ID
# Set to your user's ID to avoid permission issues (run `id` in terminal to find out)
PUID=1000
PGID=1000
